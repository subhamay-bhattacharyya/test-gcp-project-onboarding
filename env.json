{
  "_comment": "GCP Project Onboarding — project configuration schema. Copy this file, rename it to project-config.json, fill in your values, and pass its contents as the `config` input to the reusable workflow.",
  "hcp": {
    "_comment": "HCP Terraform workspace settings",
    "organization": "subhamay-gcp-projects",
    "workspace_name": "test-workspace",
    "terraform_version": "1.7.0",
    "execution_mode": "remote",
    "working_directory": "",
    "branch": "main",
    "auto_apply": false,
    "tfe_address": "https://app.terraform.io",
    "workspace_variables": [
      {
        "_comment": "Add any Terraform or environment variables to seed on the workspace.",
        "key": "TF_VAR_region",
        "value": "europe-west2",
        "sensitive": false,
        "category": "terraform"
      },
      {
        "key": "GOOGLE_CREDENTIALS",
        "value": "",
        "sensitive": true,
        "category": "env"
      }
    ]
  },
  "environments": [
    {
      "name": "devl",
      "gcp_project_id": "my-app-dev-123456"
    },
    {
      "name": "test",
      "gcp_project_id": "my-app-test-789012"
    },
    {
      "name": "prod",
      "gcp_project_id": "my-app-prod-345678"
    }
  ],
  "github": {
    "_comment": "GitHub Environment protection settings",
    "production_environment": "prod",
    "reviewer_teams": [
      "my-team"
    ],
    "wait_timer": 5
  },
  "ruleset": {
    "_comment": "Repository ruleset (branch protection) settings",
    "enabled": true,
    "target_branch": "~DEFAULT_BRANCH",
    "require_pr": true,
    "required_approvals": 1,
    "dismiss_stale_reviews": true,
    "required_status_checks": [
      "ci / build",
      "ci / test"
    ],
    "block_force_pushes": true,
    "prevent_deletion": true,
    "branch_name_pattern": "^(feature|bugfix|hotfix|release|chore)/GHA-[0-9]+-[a-z0-9-]+$",
    "_comment_branch_name_pattern": "Enforces branch naming: <type>/GHA-<number>-<description> e.g. feature/GHA-0001-feat-implement-onboarding"
  }
}
